/* 全局样式 - 纸本书房气质 */
page {
  --primary-color: #4a4238;
  --primary-light: #8d7a5f;
  --bg-color: #f2eadf;
  --paper-color: #fbf4e8;
  --paper-light: #fffaf0;
  --surface-color: #fff8ec;
  --surface-strong: #fffdf7;
  --text-primary: #24211d;
  --text-secondary: #514a42;
  --text-muted: #827a70;
  --border-color: rgba(74, 60, 43, 0.18);
  --seal-color: #a64231;
  --seal-dark: #7a2d24;
  --ink-color: #22201c;
  --gold-color: #b07a1f;
  --paper-line: rgba(36, 33, 29, 0.08);
  --page-bg-image:
    linear-gradient(180deg, #f6efe5 0%, #efe4d6 100%);
  --page-bg-size: auto;

  min-height: 100%;
  background-color: var(--bg-color);
  background-image: var(--page-bg-image);
  background-size: var(--page-bg-size);
  background-attachment: fixed;
  color: var(--text-primary);
  font-family: 'TimeLagSerif', 'Songti SC', 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', serif;
  font-size: 32rpx;
  line-height: 1.8;
}

.container {
  min-height: 100vh;
  background-color: var(--bg-color);
  background-image: var(--page-bg-image);
  background-size: var(--page-bg-size);
}

/* 纸页卡片 */
.paper-card {
  background: var(--surface-color);
  background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.72) 0%, rgba(251, 244, 232, 0.92) 100%);
  border-radius: 8rpx;
  border: 1rpx solid var(--border-color);
  box-shadow:
    0 12rpx 36rpx rgba(74, 60, 43, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.84);
  padding: 40rpx;
  margin: 24rpx;
  position: relative;
}

/* 纸张边缘做旧纹理 */
.paper-card::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  right: 6rpx;
  bottom: 6rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(36, 33, 29, 0.06);
  pointer-events: none;
}

/* 按钮样式 */
.btn-primary {
  background: var(--seal-color);
  color: var(--paper-light);
  border-radius: 4rpx;
  padding: 28rpx 64rpx;
  font-size: 30rpx;
  font-weight: 400;
  text-align: center;
  border: none;
  box-shadow:
    0 8rpx 18rpx rgba(163, 58, 42, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
  letter-spacing: 4rpx;
  line-height: 1;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  box-shadow:
    0 3rpx 8rpx rgba(163, 58, 42, 0.18),
    inset 0 3rpx 8rpx rgba(0, 0, 0, 0.12);
}

.btn-primary[disabled] {
  opacity: 1;
  background: #e5ddd1;
  color: #8b8175;
  box-shadow:
    0 8rpx 18rpx rgba(74, 60, 43, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
}

.btn-secondary {
  background: transparent;
  color: var(--primary-color);
  border: 1rpx solid var(--border-color);
  border-radius: 4rpx;
  padding: 27rpx 64rpx;
  font-size: 30rpx;
  font-weight: 400;
  text-align: center;
  letter-spacing: 4rpx;
  line-height: 1;
}

.btn-secondary::after {
  border: none;
}

.btn-secondary:active {
  background: rgba(36, 33, 29, 0.06);
}

/* 输入框样式 */
.input-field {
  background: rgba(255, 250, 240, 0.9);
  border-radius: 6rpx;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border-color);
  transition: border-color 0.2s;
}

.input-field:focus {
  border-color: var(--primary-color);
}

/* 文本域样式 */
.textarea-field {
  background: var(--paper-color);
  border-radius: 8rpx;
  padding: 32rpx;
  font-size: 32rpx;
  line-height: 2;
  min-height: 600rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 信件字体：云字体加载成功后使用 TimeLagKaiti，失败时回退系统字体 */
.handwriting {
  font-family: 'TimeLagKaiti', 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'TimeLagSerif', 'Songti SC', serif;
  font-weight: 400;
  font-synthesis: none;
  line-height: 2;
  color: var(--ink-color);
  letter-spacing: 2rpx;
}

/* 火漆印章装饰 - 多层阴影营造立体压印感 */
.seal {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #bd4b3a 0%, #a33a2a 48%, #702219 100%);
  border: 2rpx solid rgba(247, 242, 232, 0.55);
  box-shadow:
    0 8rpx 18rpx rgba(36, 33, 29, 0.22),
    inset 0 -4rpx 8rpx rgba(0, 0, 0, 0.22),
    inset 0 4rpx 10rpx rgba(255, 226, 210, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 235, 220, 0.95);
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

/* 页面标题 */
.page-title {
  font-size: 40rpx;
  font-weight: 300;
  text-align: center;
  margin: 48rpx 0;
  letter-spacing: 4rpx;
}

/* 副标题 */
.page-subtitle {
  font-size: 28rpx;
  color: var(--text-muted);
  text-align: center;
  margin-top: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: var(--text-muted);
}

/* 提示信息 */
.tip {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
  padding: 24rpx;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 32rpx 0;
}

/* 徽章 */
.badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.badge-primary {
  background: rgba(180, 140, 120, 0.1);
  color: var(--primary-color);
}

.badge-success {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.badge-warning {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning-color);
}
