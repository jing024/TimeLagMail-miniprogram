/* pages/letter-detail/letter-detail.wxss */
.container {
  min-height: 100vh;
  padding: 0 34rpx 48rpx;
  background-color: #f5eee3;
  background-image:
    linear-gradient(180deg, #fbf6ec 0%, #f2e7d8 100%);
}

.container.detail-sent {
  --detail-accent: #4d4841;
  --detail-accent-soft: rgba(77, 72, 65, 0.10);
  --detail-accent-line: rgba(77, 72, 65, 0.56);
}

.container.detail-received {
  --detail-accent: #a64231;
  --detail-accent-soft: rgba(166, 66, 49, 0.11);
  --detail-accent-line: rgba(166, 66, 49, 0.62);
}

.container.detail-sent,
.container.detail-received {
  --detail-gold-line: rgba(176, 122, 31, 0.64);
}

/* 信件信息 */
.letter-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 36rpx 8rpx 28rpx;
  border-bottom: 1rpx solid rgba(74, 60, 43, 0.13);
  margin-bottom: 28rpx;
}

.meta-date {
  font-size: 26rpx;
  color: var(--text-muted);
  letter-spacing: 3rpx;
}

.meta-author {
  font-size: 22rpx;
  color: var(--detail-accent, var(--seal-color));
  letter-spacing: 3rpx;
  padding: 5rpx 16rpx;
  background: var(--detail-accent-soft, rgba(163, 58, 42, 0.08));
  border: 1rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 4rpx;
}

/* 信纸 */
.letter-paper {
  min-height: 600rpx;
  padding: 72rpx 54rpx;
  margin-bottom: 48rpx;
  position: relative;
  background: #fffaf1;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 56rpx,
      var(--paper-line) 56rpx,
      var(--paper-line) 57rpx
    ),
    linear-gradient(180deg, rgba(255, 255, 255, 0.90) 0%, rgba(255, 249, 238, 0.98) 100%);
  border-radius: 8rpx;
  border: 1rpx solid rgba(74, 60, 43, 0.16);
  box-shadow:
    0 18rpx 44rpx rgba(74, 60, 43, 0.13),
    0 2rpx 0 rgba(255, 255, 255, 0.82) inset;

  /* 初始折叠状态 */
  opacity: 0;
  transform: scaleY(0.85) translateY(20rpx);
  transform-origin: top center;
}

/* 信纸内边缘暗纹 */
.letter-paper::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(36, 33, 29, 0.055);
  pointer-events: none;
}

.letter-paper::after {
  content: '';
  position: absolute;
  top: 0;
  left: 54rpx;
  right: 54rpx;
  height: 5rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: linear-gradient(
    90deg,
    var(--detail-accent-line, rgba(166, 66, 49, 0.56)) 0%,
    var(--detail-gold-line, rgba(176, 122, 31, 0.56)) 45%,
    rgba(166, 66, 49, 0.38) 100%
  );
  opacity: 0.86;
  pointer-events: none;
}

/* 展开动画 */
.letter-paper.unfold {
  opacity: 1;
  transform: scaleY(1) translateY(0);
  transition: opacity 0.5s ease-out, transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
}

.letter-paper.favorited {
  border-color: rgba(176, 122, 31, 0.54);
  box-shadow:
    0 18rpx 44rpx rgba(74, 60, 43, 0.13),
    0 0 0 2rpx rgba(176, 122, 31, 0.13),
    0 2rpx 0 rgba(255, 255, 255, 0.82) inset;
}

/* 火漆印章 */
.wax-seal-badge {
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
  width: 72rpx;
  height: 72rpx;
  opacity: 0.72;
  z-index: 1;
}

/* 信件正文 */
.letter-content {
  font-size: 34rpx;
  line-height: 2.08;
  color: var(--ink-color);
  font-family: 'TimeLagKaiti', 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'TimeLagSerif', 'Songti SC', serif;
  letter-spacing: 1rpx;
  white-space: pre-wrap;
  word-break: break-all;
  padding-bottom: 92rpx;
}

.letter-image-wrap {
  margin-top: 12rpx;
  margin-bottom: 92rpx;
  padding: 14rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 6rpx;
  background: rgba(255, 253, 247, 0.84);
  position: relative;
  z-index: 2;
}

.letter-image {
  width: 100%;
  display: block;
  border-radius: 4rpx;
}

/* 操作区 */
.action-area {
  display: flex;
  gap: 24rpx;
}

.action-area .btn-secondary,
.action-area .btn-primary {
  flex: 1;
}

.action-area .btn-secondary {
  background: rgba(255, 250, 241, 0.72);
  border-color: rgba(74, 60, 43, 0.18);
}

.action-area .btn-primary {
  background: var(--detail-accent, var(--seal-color));
  box-shadow:
    0 8rpx 18rpx rgba(77, 72, 65, 0.16),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

/* 收藏激活态 — 覆盖 btn-secondary 默认样式 */
.action-area .btn-secondary.favorited {
  background: var(--gold-color);
  color: var(--paper-light);
  border-color: var(--gold-color);
}
