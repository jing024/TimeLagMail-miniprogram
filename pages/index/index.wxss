/* pages/index/index.wxss - 书房封面 */

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 56rpx 40rpx 40rpx;
  box-sizing: border-box;
  --home-sent: #4d4841;
  --home-received: #a64231;
  --home-gold-soft: rgba(176, 122, 31, 0.12);
}

/* 欢迎区域 - 常驻视觉 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  position: relative;
}

.welcome-section::before {
  content: '';
  width: 1rpx;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(63, 60, 55, 0.30), rgba(166, 66, 49, 0.34));
  margin-bottom: 40rpx;
}

.logo {
  margin-bottom: 34rpx;
}

.logo-icon {
  width: 148rpx;
  height: 148rpx;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  opacity: 0.92;
}

.title {
  writing-mode: vertical-rl;
  font-size: 62rpx;
  font-weight: 400;
  letter-spacing: 16rpx;
  line-height: 1.1;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  font-family: 'TimeLagSerif', 'Songti SC', 'Noto Serif SC', serif;
  transform: translateX(-28rpx);
}

.english-name {
  font-size: 18rpx;
  color: var(--text-muted);
  letter-spacing: 6rpx;
  margin-bottom: 42rpx;
  font-weight: 300;
  text-transform: uppercase;
  font-family: 'Times New Roman', serif;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 44rpx;
  font-weight: 400;
  letter-spacing: 6rpx;
  font-family: 'TimeLagSerif', 'Songti SC', 'Noto Serif SC', serif;
}

/* 统计数字区域 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 48rpx;
  padding: 32rpx 54rpx;
  background: var(--surface-strong);
  background-image:
    linear-gradient(90deg, rgba(63, 60, 55, 0.045) 0%, rgba(176, 122, 31, 0.035) 48%, rgba(166, 66, 49, 0.050) 100%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.86) 0%, rgba(255, 249, 238, 0.96) 100%);
  border-radius: 8rpx;
  border: 1rpx solid rgba(74, 60, 43, 0.16);
  box-shadow:
    0 14rpx 34rpx rgba(74, 60, 43, 0.11),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.82);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 16rpx 32rpx;
}

.stat-item::after {
  content: '';
  width: 42rpx;
  height: 3rpx;
  margin-top: 12rpx;
  border-radius: 3rpx;
  opacity: 0.72;
}

.stat-sent::after {
  background: var(--home-sent);
}

.stat-received::after {
  background: var(--home-received);
}

.stat-number {
  font-size: 54rpx;
  font-weight: 300;
  color: var(--text-primary);
  font-family: 'Times New Roman', serif;
  line-height: 1.2;
}

.stat-sent .stat-number {
  color: var(--home-sent);
}

.stat-received .stat-number {
  color: var(--home-received);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  letter-spacing: 3rpx;
}

.stat-badge {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--home-received);
  color: var(--paper-light);
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(63, 60, 55, 0.22), rgba(176, 122, 31, 0.28), rgba(166, 66, 49, 0.24));
}

.description {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 32rpx 48rpx;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.description text {
  font-size: 26rpx;
  color: var(--text-muted);
  margin: 8rpx 0;
  font-weight: 400;
  letter-spacing: 6rpx;
  font-family: 'TimeLagSerif', 'Noto Serif SC', serif;
}

.login-btn {
  width: 320rpx;
  margin-top: 20rpx;
}

/* 操作按钮 */
.action-buttons {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.action-buttons .btn-primary {
  width: 320rpx;
}

.partner-status {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 3rpx;
  margin-top: 16rpx;
}

/* 底部导航 */
.bottom-nav {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(176, 122, 31, 0.20);
}

.nav-item {
  padding: 14rpx 32rpx;
}

.nav-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 4rpx;
}
