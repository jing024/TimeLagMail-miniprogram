/* pages/index/index.wxss - 重新设计的首页样式 */

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 60rpx 40rpx 40rpx;
  box-sizing: border-box;
}

/* 欢迎区域 - 常驻视觉 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
}

.logo {
  margin-bottom: 40rpx;
}

.logo-icon {
  width: 180rpx;
  height: 180rpx;
  /* 无边框无阴影，透明背景直接融入页面 */
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.title {
  font-size: 64rpx;
  font-weight: 400;
  letter-spacing: 20rpx;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-family: 'Noto Serif SC', serif;
}

.english-name {
  font-size: 20rpx;
  color: var(--text-muted);
  letter-spacing: 8rpx;
  margin-bottom: 48rpx;
  font-weight: 300;
  text-transform: uppercase;
  font-family: 'Times New Roman', serif;
}

.subtitle {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  font-family: 'Noto Serif SC', serif;
}

/* 统计数字区域 - 去掉边框，改用内阴影圆角卡片 */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 48rpx;
  padding: 36rpx 56rpx;
  background: var(--paper-light);
  background-image:
    radial-gradient(ellipse at 40% 0%, rgba(255, 252, 245, 0.5) 0%, transparent 60%);
  border-radius: 16rpx;
  border: none;
  box-shadow:
    inset 0 2rpx 8rpx rgba(255, 252, 245, 0.7),
    inset 0 -2rpx 8rpx rgba(61, 41, 20, 0.08),
    0 2rpx 6rpx rgba(61, 41, 20, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 16rpx 32rpx;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 300;
  color: var(--text-primary);
  font-family: 'Times New Roman', serif;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.stat-badge {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--seal-color);
  color: #f0e6d6;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background: var(--border-color);
}

.description {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 32rpx 48rpx;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.description text {
  font-size: 26rpx;
  color: var(--text-muted);
  margin: 8rpx 0;
  font-weight: 400;
  letter-spacing: 6rpx;
  font-family: 'Noto Serif SC', serif;
}

.login-btn {
  width: 320rpx;
  margin-top: 20rpx;
}

/* 操作按钮 */
.action-buttons {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.action-buttons .btn-primary {
  width: 320rpx;
}

.partner-status {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  margin-top: 16rpx;
}

/* 底部导航 */
.bottom-nav {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.nav-item {
  padding: 16rpx 32rpx;
}

.nav-text {
  font-size: 30rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
}
