/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding: 40rpx;
}

/* 欢迎区域 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.logo {
  margin-bottom: 48rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--seal-color);
  border: 4rpx solid rgba(240, 230, 214, 0.4);
  box-shadow: 
    0 4rpx 12rpx rgba(61, 41, 20, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  font-size: 48rpx;
  color: #f0e6d6;
}

.title {
  font-size: 52rpx;
  font-weight: 400;
  letter-spacing: 20rpx;
  margin-bottom: 12rpx;
  color: var(--text-primary);
  font-family: 'Noto Serif SC', serif;
}

.english-name {
  font-size: 20rpx;
  color: var(--text-muted);
  letter-spacing: 8rpx;
  margin-bottom: 32rpx;
  font-weight: 300;
  text-transform: uppercase;
  font-family: 'Times New Roman', serif;
}

.subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 80rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  font-family: 'Noto Serif SC', serif;
}

.description {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  padding: 32rpx 48rpx;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.description text {
  font-size: 24rpx;
  color: var(--text-muted);
  margin: 12rpx 0;
  font-weight: 400;
  letter-spacing: 6rpx;
  font-family: 'Noto Serif SC', serif;
}

.login-btn {
  margin-top: 60rpx;
  width: 320rpx;
}

/* 用户信息 */
.user-info {
  margin-bottom: 48rpx;
}

.greeting {
  font-size: 36rpx;
  color: var(--text-secondary);
}

.card-content {
  text-align: center;
  padding: 40rpx 0;
}

.card-title {
  display: block;
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.card-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-muted);
}

/* 首页内容 */
.home-content {
  padding-top: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header .greeting {
  display: block;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.partner-info {
  display: block;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 状态卡片 */
.status-card {
  margin-bottom: 48rpx;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.status-date {
  font-size: 32rpx;
  font-weight: 500;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.status-badge.written {
  background: rgba(74, 74, 74, 0.08);
  color: var(--text-secondary);
}

.status-badge.not-written {
  background: transparent;
  color: var(--text-muted);
  border: 1rpx solid var(--border-color);
}

.streak-info {
  padding-top: 24rpx;
  border-top: 2rpx solid var(--border-color);
}

.streak-text {
  font-size: 26rpx;
  color: var(--text-muted);
  font-weight: 300;
  letter-spacing: 2rpx;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.action-buttons .btn-primary,
.action-buttons .btn-secondary {
  width: 100%;
  box-sizing: border-box;
}

.action-buttons .btn-primary.disabled {
  opacity: 0.5;
}
