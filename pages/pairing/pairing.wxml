<!-- pages/pairing/pairing.wxml -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 已配对状态 -->
  <block wx:elif="{{isPaired}}">
    <view class="paired-section">
      <view class="success-icon">💕</view>
      <view class="success-title">配对成功</view>
      <view class="partner-card paper-card">
        <image class="partner-avatar" src="{{partnerInfo.avatarUrl}}" mode="aspectFill" wx:if="{{partnerInfo.avatarUrl}}"/>
        <view class="partner-name">{{partnerInfo.nickName || 'Ta'}}</view>
        <view class="partner-desc">你们已经开始交换日记</view>
      </view>
      <button class="btn-primary" bindtap="goHome">开始写信</button>
    </view>
  </block>

  <!-- 未配对状态 -->
  <block wx:else>
    <view class="pairing-section">
      <view class="page-title">配对</view>

      <!-- 方式一：生成邀请码 -->
      <view class="method-section">
        <view class="method-label">方式一</view>
        <block wx:if="{{myInviteCode}}">
          <view class="paper-card invite-card">
            <view class="invite-label">你的邀请码</view>
            <view class="invite-code">{{myInviteCode}}</view>
            <view class="invite-tip">让 Ta 输入这个邀请码即可配对</view>
            <view class="invite-expire">有效期至：{{inviteExpire}}</view>
          </view>
          <!-- 配对成功通知（仅方式一下显示） -->
          <button class="btn-subscribe" bindtap="subscribePairing" wx:if="{{!subscribedPairing}}">
            开启配对成功通知
          </button>
        </block>
        <block wx:else>
          <button class="btn-primary btn-generate" bindtap="createInvite" loading="{{creating}}">
            生成邀请码
          </button>
        </block>
      </view>

      <!-- 方式二：输入邀请码 -->
      <view class="method-section">
        <view class="method-label">方式二</view>
        <view class="paper-card input-card">
          <view class="input-label">输入 Ta 的邀请码</view>
          <input class="invite-input" 
                 type="text" 
                 maxlength="6"
                 placeholder="6位邀请码"
                 value="{{inputCode}}"
                 bindinput="onCodeInput"/>
          <button class="btn-secondary {{inputCode.length !== 6 ? 'disabled' : ''}}"
                  bindtap="acceptInvite"
                  disabled="{{inputCode.length !== 6 || accepting}}"
                  loading="{{accepting}}">
            确认配对
          </button>
        </view>
      </view>

      <!-- 错误提示 -->
      <view class="error-tip" wx:if="{{error}}">{{error}}</view>
    </view>
  </block>
</view>
