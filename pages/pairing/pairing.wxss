/* pages/pairing/pairing.wxss */

/* ===== 通用 ===== */
.container {
  min-height: 100vh;
  padding: 40rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: var(--text-muted);
}

/* ===== 配对成功 ===== */
.paired-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.success-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 300;
  margin-bottom: 48rpx;
}

.partner-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 80rpx;
  margin-bottom: 48rpx;
}

.partner-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 24rpx;
  background: var(--bg-color);
}

.partner-name {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.partner-desc {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* ===== 配对区域 ===== */
.pairing-section {
  padding-top: 40rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 300;
  text-align: center;
  margin-bottom: 48rpx;
}

/* ===== 方式区块 ===== */
.method-section {
  margin-bottom: 48rpx;
}

.method-label {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  margin: 0 24rpx 20rpx;
}

/* ===== 邀请码卡片 ===== */
.invite-card {
  text-align: center;
  padding: 48rpx 32rpx;
  background: var(--paper-light);
  background-image:
    radial-gradient(ellipse at 40% 0%, rgba(255, 252, 245, 0.5) 0%, transparent 60%);
  border-radius: 16rpx;
  border: none;
  box-shadow:
    inset 0 2rpx 6rpx rgba(255, 252, 245, 0.6),
    inset 0 -2rpx 6rpx rgba(61, 41, 20, 0.07),
    0 2rpx 6rpx rgba(61, 41, 20, 0.08);
  margin-bottom: 0;
}

.invite-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.invite-code {
  font-size: 56rpx;
  font-weight: 500;
  letter-spacing: 12rpx;
  color: var(--seal-color);
  margin-bottom: 24rpx;
  font-family: 'Courier New', monospace;
  text-align: center;
}

.invite-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.invite-expire {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

/* ===== 生成按钮 ===== */
.btn-generate {
  width: 100%;
  box-sizing: border-box;
}

/* ===== 输入卡片 ===== */
.input-card {
  padding: 40rpx 32rpx;
  background: var(--paper-light);
  background-image:
    radial-gradient(ellipse at 40% 0%, rgba(255, 252, 245, 0.5) 0%, transparent 60%);
  border-radius: 16rpx;
  border: none;
  box-shadow:
    inset 0 2rpx 6rpx rgba(255, 252, 245, 0.6),
    inset 0 -2rpx 6rpx rgba(61, 41, 20, 0.07),
    0 2rpx 6rpx rgba(61, 41, 20, 0.08);
  margin-bottom: 0;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.invite-input {
  background: rgba(139, 115, 85, 0.08);
  border-radius: 10rpx;
  padding: 28rpx 24rpx;
  font-size: 36rpx;
  font-family: inherit;
  text-align: center;
  letter-spacing: 8rpx;
  margin-bottom: 24rpx;
  border: none;
  box-shadow: inset 0 2rpx 6rpx rgba(61, 41, 20, 0.1);
  width: 100%;
  box-sizing: border-box;
  min-height: 96rpx;
  color: var(--text-primary);
}

.invite-input:focus {
  box-shadow: inset 0 2rpx 8rpx rgba(139, 26, 26, 0.15);
}

.invite-input::placeholder {
  font-size: 30rpx;
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', serif;
  letter-spacing: 2rpx;
  color: var(--text-muted);
  opacity: 0.7;
}

/* 确认配对按钮 */
.input-card .btn-secondary {
  background: var(--seal-color);
  color: rgba(255, 240, 228, 0.92);
  border-radius: 8rpx;
  padding: 24rpx 64rpx;
  font-size: 30rpx;
  font-family: inherit;
  letter-spacing: 4rpx;
  line-height: 1;
  width: 100%;
  box-sizing: border-box;
  border: none;
  box-shadow:
    0 4rpx 12rpx rgba(139, 26, 26, 0.3),
    inset 0 1rpx 0 rgba(255, 200, 180, 0.2),
    inset 0 -1rpx 0 rgba(0, 0, 0, 0.1);
}

.input-card .btn-secondary::after {
  border: none;
}

.input-card .btn-secondary.disabled {
  opacity: 0.4;
  background: var(--text-muted);
  box-shadow: none;
}

/* ===== 错误提示 ===== */
.error-tip {
  text-align: center;
  color: var(--error-color);
  font-size: 28rpx;
  margin-top: 32rpx;
}

/* ===== 订阅按钮 ===== */
.btn-subscribe {
  margin: 24rpx auto 0;
  background: transparent;
  border: 2rpx solid var(--seal-color);
  color: var(--seal-color);
  font-size: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 8rpx;
  line-height: 1.8;
  display: block;
  letter-spacing: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 26, 26, 0.12);
}
