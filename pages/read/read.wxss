/* pages/read/read.wxss - 信件列表样式 */
.container {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  letter-spacing: 8rpx;
  color: var(--text-primary);
}

.header-count {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: var(--text-muted);
}

/* 信件列表 */
.letters-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.letter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--paper-light);
  background-image:
    radial-gradient(ellipse at 30% 0%, rgba(255, 252, 245, 0.5) 0%, transparent 60%);
  border-radius: 12rpx;
  border: none;
  box-shadow:
    inset 0 2rpx 6rpx rgba(255, 252, 245, 0.6),
    inset 0 -1rpx 4rpx rgba(61, 41, 20, 0.07),
    0 1rpx 3rpx rgba(61, 41, 20, 0.06);
  padding: 24rpx 32rpx;
}

.letter-item.unread {
  border-left: 5rpx solid var(--seal-color);
}

.letter-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  margin-right: 16rpx;
}

.letter-date {
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.letter-preview {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.letter-status {
  padding: 4rpx 16rpx;
  border-radius: 2rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
}

.letter-status.read {
  background: rgba(139, 115, 85, 0.1);
  color: var(--text-muted);
}

.letter-status.unread {
  background: var(--seal-color);
  color: #f0e6d6;
}

/* 等待解锁提示 */
.pending-notice {
  text-align: center;
  padding: 32rpx;
  margin-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.pending-notice text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.pending-idle text {
  color: var(--text-muted);
  opacity: 0.75;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 48rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
