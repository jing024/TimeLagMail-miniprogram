/* pages/read/read.wxss - 信件列表样式 */
.container {
  min-height: 100vh;
  padding: 0 34rpx 48rpx;
  --received-accent: #a64231;
  --received-accent-soft: rgba(166, 66, 49, 0.10);
  --received-accent-border: rgba(166, 66, 49, 0.30);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 8rpx 28rpx;
  border-bottom: 1rpx solid rgba(166, 66, 49, 0.18);
  margin-bottom: 28rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 400;
  letter-spacing: 8rpx;
  color: var(--text-primary);
  position: relative;
}

.header-title::after {
  content: '';
  display: block;
  width: 52rpx;
  height: 3rpx;
  margin-top: 10rpx;
  background: var(--received-accent);
  opacity: 0.72;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-count {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 收藏筛选按钮 */
.filter-btn {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  padding: 6rpx 14rpx;
  border-radius: 4rpx;
  border: 1rpx solid var(--border-color);
}

.filter-btn.active {
  color: var(--paper-light);
  background: var(--gold-color);
  border-color: var(--gold-color);
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: var(--text-muted);
}

/* 信件列表 */
.letters-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.month-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.month-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 8rpx 4rpx 16rpx;
  border-bottom: 1rpx solid rgba(166, 66, 49, 0.14);
}

.month-title {
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

.month-summary {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.month-toggle {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--received-accent);
  letter-spacing: 2rpx;
  padding-left: 20rpx;
}

.month-letters {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.letter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff9ee;
  background-image:
    linear-gradient(90deg, rgba(166, 66, 49, 0.070) 0%, rgba(176, 122, 31, 0.030) 40%, rgba(166, 66, 49, 0) 74%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(255, 248, 236, 0.96) 100%);
  border-radius: 6rpx;
  border: 1rpx solid var(--received-accent-border);
  border-left: 4rpx solid var(--received-accent);
  box-shadow:
    0 8rpx 22rpx rgba(166, 66, 49, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
  padding: 26rpx 30rpx;
}

.letter-item.unread {
  border-color: rgba(166, 66, 49, 0.28);
  border-left-color: var(--seal-color);
  background-image:
    linear-gradient(90deg, rgba(166, 66, 49, 0.085) 0%, rgba(166, 66, 49, 0) 36%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.86) 0%, rgba(255, 248, 236, 0.96) 100%);
}

.letter-item.favorited {
  border-color: rgba(176, 122, 31, 0.54);
  border-left-color: var(--gold-color);
  background-image:
    linear-gradient(90deg, rgba(176, 122, 31, 0.13) 0%, rgba(176, 122, 31, 0.035) 42%, rgba(176, 122, 31, 0) 76%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(255, 248, 236, 0.96) 100%);
  box-shadow:
    0 8rpx 22rpx rgba(176, 122, 31, 0.11),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.78);
}

.letter-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  margin-right: 16rpx;
}

.letter-date {
  font-size: 25rpx;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.letter-preview {
  font-size: 25rpx;
  color: var(--text-muted);
  margin-left: 18rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.letter-image-mark {
  flex-shrink: 0;
  margin-left: 14rpx;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(63, 60, 55, 0.16);
  color: #4d4841;
  background: rgba(63, 60, 55, 0.055);
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.letter-status {
  padding: 5rpx 14rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
}

.letter-status.read {
  background: var(--received-accent-soft);
  color: var(--received-accent);
}

.letter-status.unread {
  background: var(--seal-color);
  color: var(--paper-light);
}

/* 等待解锁提示 */
.pending-notice {
  text-align: center;
  padding: 32rpx;
  margin-top: 32rpx;
  border-top: 1rpx solid var(--border-color);
}

.pending-notice text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.pending-idle text {
  color: var(--text-muted);
  opacity: 0.75;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 48rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
