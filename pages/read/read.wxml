<!-- pages/read/read.wxml - 收到的所有信件列表 -->
<view class="container">
  <view class="header">
    <view class="header-title">已收到</view>
    <view class="header-right">
      <text class="header-count" wx:if="{{letters.length > 0}}">共 {{letters.length}} 封</text>
      <text class="filter-btn {{favoriteOnly ? 'active' : ''}}" bindtap="toggleFavoriteFilter">仅收藏</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 信件列表 -->
  <view class="letters-list" wx:elif="{{letters.length > 0}}">
    <view class="month-group" wx:for="{{monthGroups}}" wx:key="key" wx:for-item="group">
      <view class="month-header" bindtap="toggleMonth" data-key="{{group.key}}">
        <view>
          <view class="month-title">{{group.title}}</view>
          <view class="month-summary">{{group.summary}}</view>
        </view>
        <text class="month-toggle">{{group.expanded ? '收起' : '展开'}}</text>
      </view>

      <view class="month-letters" wx:if="{{group.expanded}}">
        <view class="letter-item {{item.isRead ? 'read' : 'unread'}} {{item.isFavorited ? 'favorited' : ''}}"
              wx:for="{{group.letters}}"
              wx:key="_id"
              wx:for-item="item"
              bindtap="openLetter"
              data-id="{{item._id}}">
          <view class="letter-left">
            <text class="letter-date">{{item.dateStr}}</text>
            <text class="letter-preview">{{item.preview}}</text>
            <text class="letter-image-mark" wx:if="{{item.imageFileID}}">附图</text>
          </view>
          <view class="letter-status {{item.isRead ? 'read' : 'unread'}}">
            {{item.isRead ? '已启' : '待启'}}
          </view>
        </view>
      </view>
    </view>

    <!-- 待解锁提示 -->
    <view class="pending-notice {{hasPending && pendingCount > 0 ? '' : 'pending-idle'}}" wx:if="{{letters.length > 0 && !favoriteOnly}}">
      <text wx:if="{{hasPending && pendingCount > 0}}">还有 {{pendingCount}} 封信件在途中</text>
      <text wx:else>静候对方落笔</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading}}">
    <view class="empty-icon">—</view>
    <view class="empty-text">{{favoriteOnly ? '尚未收藏信件' : '尚未收到信件'}}</view>
    <view class="empty-hint">{{favoriteOnly ? '在信件详情中点击收藏' : '等待对方的第一封信'}}</view>
  </view>
</view>
