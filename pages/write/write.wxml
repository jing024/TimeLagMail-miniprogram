<!-- pages/write/write.wxml -->
<view class="container">
  <view class="header">
    <view class="header-title">书写</view>
    <view class="header-tip">{{deliveryDateStr}}</view>
  </view>

  <!-- 信纸区域 -->
  <view class="paper-card letter-paper">
    <!-- 右下角火漆印章 -->
    <image class="wax-seal-badge" src="/assets/wax_seal_4_clean.png" mode="aspectFit" />
    <view class="textarea-placeholder handwriting" wx:if="{{!content && !textareaFocused}}">
      此刻，你想对远方的人说什么...
    </view>
    <textarea class="letter-textarea handwriting"
              placeholder=""
              maxlength="2000"
              bindinput="onInput"
              bindfocus="onTextareaFocus"
              bindblur="onTextareaBlur"
              value="{{content}}"/>
    <view class="char-count {{content.length >= 1800 ? 'warning' : ''}}">
      {{content.length}} / 2000
    </view>
  </view>

  <!-- 附图 -->
  <view class="image-attachment">
    <view class="attach-action" wx:if="{{!selectedImagePath}}" bindtap="chooseImage">
      <text>附图</text>
    </view>
    <view class="attached-image" wx:else>
      <image class="attached-preview" src="{{selectedImagePath}}" mode="aspectFill" />
      <view class="attached-meta">
        <text>附图</text>
        <text class="remove-image" bindtap="removeImage">移除</text>
      </view>
    </view>
  </view>

  <!-- 送达天数选择 -->
  <view class="delivery-picker">
    <view class="delivery-label">几天后送达</view>
    <scroll-view class="delivery-days" scroll-x enable-flex>
      <view wx:for="{{dayOptions}}" wx:key="*this"
            class="day-btn {{deliveryDays === item ? 'active' : ''}}"
            data-days="{{item}}"
            bindtap="selectDeliveryDays">
        {{item}}
      </view>
    </scroll-view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-secondary" bindtap="goBack">搁置</button>
    <button class="btn-primary {{!canSubmit ? 'disabled' : ''}}"
            bindtap="submitLetter"
            disabled="{{!canSubmit || submitting}}">
      封缄
    </button>
  </view>

  <!-- 提示 -->
  <view class="bottom-tip">
    <text>封缄后不可更改</text>
  </view>
</view>
