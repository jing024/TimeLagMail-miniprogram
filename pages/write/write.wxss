/* pages/write/write.wxss */
.container {
  min-height: 100vh;
  padding: 0 34rpx 48rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 8rpx 28rpx;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 28rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 6rpx;
  color: var(--text-primary);
}

.header-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 信纸 */
.letter-paper {
  min-height: 800rpx;
  padding: 72rpx 54rpx;
  margin-bottom: 48rpx;
  position: relative;
  background: var(--surface-strong);
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 56rpx,
      var(--paper-line) 56rpx,
      var(--paper-line) 57rpx
    ),
    linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(251, 244, 232, 0.94) 100%);
  border-radius: 8rpx;
  border: 1rpx solid var(--border-color);
  box-shadow:
    0 14rpx 40rpx rgba(74, 60, 43, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86);
}

/* 信纸内边缘暗纹 */
.letter-paper::before {
  content: '';
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(36, 33, 29, 0.055);
  pointer-events: none;
}

/* 火漆印章 - 缩小版真实印章图片 */
.wax-seal-badge {
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
  width: 72rpx;
  height: 72rpx;
  opacity: 0.72;
  z-index: 1;
}

.letter-textarea {
  width: 100%;
  min-height: 600rpx;
  font-size: 34rpx;
  line-height: 2.08;
  color: var(--ink-color);
  background: transparent;
  font-family: 'TimeLagKaiti', 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'TimeLagSerif', 'Songti SC', serif;
  letter-spacing: 1rpx;
}

.textarea-placeholder {
  position: absolute;
  top: 72rpx;
  left: 54rpx;
  right: 54rpx;
  color: var(--text-muted);
  font-size: 32rpx;
  line-height: 2.08;
  font-family: 'TimeLagKaiti', 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'TimeLagSerif', 'Songti SC', serif;
  letter-spacing: 1rpx;
  pointer-events: none;
  z-index: 1;
}

.char-count {
  position: absolute;
  bottom: 138rpx;
  right: 54rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: 'Times New Roman', serif;
}

.char-count.warning {
  color: var(--seal-color);
}

/* 附图 */
.image-attachment {
  margin: 0 24rpx 40rpx;
}

.attach-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 4rpx;
  border: 1rpx solid var(--border-color);
  color: var(--text-muted);
  font-size: 24rpx;
  letter-spacing: 4rpx;
  background: rgba(251, 248, 240, 0.58);
}

.attached-image {
  border: 1rpx solid var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
  background: rgba(251, 248, 240, 0.7);
}

.attached-preview {
  width: 100%;
  height: 260rpx;
  display: block;
}

.attached-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 22rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 3rpx;
  border-top: 1rpx solid var(--border-color);
}

.remove-image {
  color: var(--seal-color);
}

/* 送达天数选择器 */
.delivery-picker {
  margin-bottom: 40rpx;
}

.delivery-label {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.delivery-days {
  display: flex;
  white-space: nowrap;
}

.day-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  background: rgba(36, 33, 29, 0.045);
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.day-btn.active {
  background: var(--seal-color);
  color: var(--paper-light);
  box-shadow: 0 6rpx 14rpx rgba(163, 58, 42, 0.2);
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-bar .btn-secondary,
.action-bar .btn-primary {
  flex: 1;
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 24rpx;
}

.bottom-tip text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}
