/* pages/write/write.wxss */
.container {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 16rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  color: var(--text-secondary);
}

.header-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 信纸 - 厚牛皮纸质感：大圆角 + 内阴影 + 细腻纹理 */
.letter-paper {
  min-height: 800rpx;
  padding: 64rpx 48rpx;
  margin-bottom: 48rpx;
  position: relative;
  background: var(--paper-light);
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 42rpx,
      rgba(139, 115, 85, 0.04) 42rpx,
      rgba(139, 115, 85, 0.04) 43rpx
    ),
    radial-gradient(ellipse at 25% 20%, rgba(255, 252, 245, 0.5) 0%, transparent 55%),
    radial-gradient(ellipse at 75% 80%, rgba(139, 115, 85, 0.08) 0%, transparent 50%);
  border-radius: 20rpx;
  border: none;
  box-shadow:
    0 4rpx 16rpx rgba(61, 41, 20, 0.12),
    0 12rpx 40rpx rgba(61, 41, 20, 0.08),
    inset 0 3rpx 10rpx rgba(255, 252, 245, 0.7),
    inset 0 -3rpx 10rpx rgba(61, 41, 20, 0.05);
}

/* 信纸内边缘暗纹 */
.letter-paper::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(139, 115, 85, 0.12);
  pointer-events: none;
}

/* 火漆印章 - 缩小版真实印章图片 */
.wax-seal-badge {
  position: absolute;
  bottom: 36rpx;
  right: 36rpx;
  width: 80rpx;
  height: 80rpx;
  opacity: 0.9;
  z-index: 1;
}

.letter-textarea {
  width: 100%;
  min-height: 600rpx;
  font-size: 32rpx;
  line-height: 2;
  color: var(--ink-color);
  background: transparent;
  font-family: 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'Songti SC', serif;
  letter-spacing: 2rpx;
}

.placeholder {
  color: var(--text-muted);
  font-size: 32rpx;
  font-family: 'STKaiti', 'KaiTi', 'PingFangSC-Regular', 'PingFang SC', 'Songti SC', serif;
}

.char-count {
  position: absolute;
  bottom: 140rpx;
  right: 48rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: 'Times New Roman', serif;
}

.char-count.warning {
  color: var(--seal-color);
}

/* 送达天数选择器 */
.delivery-picker {
  margin-bottom: 40rpx;
}

.delivery-label {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.delivery-days {
  display: flex;
  white-space: nowrap;
}

.day-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  font-size: 26rpx;
  color: var(--text-muted);
  background: rgba(139, 115, 85, 0.06);
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.day-btn.active {
  background: var(--seal-color);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(183, 58, 42, 0.3);
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-bar .btn-secondary,
.action-bar .btn-primary {
  flex: 1;
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 24rpx;
}

.bottom-tip text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}
