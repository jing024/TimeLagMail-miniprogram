/* pages/timeline/timeline.wxss - 书签式时间轴 */
.container {
  min-height: 100vh;
  padding: 0 34rpx 48rpx;
  --timeline-sent: #4d4841;
  --timeline-received: #a64231;
  --timeline-received-soft: rgba(166, 66, 49, 0.10);
  --timeline-sent-soft: rgba(77, 72, 65, 0.09);
  --timeline-gold-soft: rgba(176, 122, 31, 0.12);
}

.header {
  padding: 34rpx 8rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 400;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
  color: var(--text-primary);
}

.streak-text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.streak-info {
  padding: 32rpx 16rpx 16rpx;
  text-align: center;
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
  padding-top: 24rpx;
  margin-bottom: 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-item text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.legend-marker {
  width: 14rpx;
  height: 14rpx;
  border-radius: 1rpx;
}

.legend-marker.sent {
  background: var(--timeline-sent);
}

.legend-marker.received {
  background: var(--timeline-received);
}

/* 收藏筛选按钮 */
.filter-btn {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  padding: 6rpx 14rpx;
  border-radius: 4rpx;
  border: 1rpx solid var(--border-color);
}

.filter-btn.active {
  color: var(--paper-light);
  background: var(--gold-color);
  border-color: var(--gold-color);
}

/* 最近 20 周通信热力图 */
.heatmap-card {
  margin-bottom: 32rpx;
  padding: 18rpx 0 28rpx;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.heatmap-filter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 0 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.heatmap-clear {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--gold-color);
  letter-spacing: 2rpx;
  padding-left: 24rpx;
}

.heatmap-layout {
  display: flex;
  align-items: flex-start;
  width: 100%;
}

.heatmap-day-labels {
  width: 52rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.heatmap-month-spacer {
  height: 28rpx;
}

.heatmap-day-label {
  height: 21rpx;
  line-height: 21rpx;
  margin-bottom: 6rpx;
  font-size: 18rpx;
  color: transparent;
  letter-spacing: 0;
}

.heatmap-day-label.visible {
  color: var(--text-muted);
}

.heatmap-grid {
  flex: 1;
  display: flex;
  justify-content: space-between;
  gap: 4rpx;
  min-width: 0;
}

.heatmap-week {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.heatmap-month-label {
  height: 22rpx;
  line-height: 22rpx;
  margin-bottom: 6rpx;
  font-size: 18rpx;
  color: var(--text-muted);
  letter-spacing: 0;
  white-space: nowrap;
}

.heatmap-day {
  width: 21rpx;
  height: 21rpx;
  box-sizing: border-box;
  border-radius: 3rpx;
  border: 1rpx solid rgba(63, 60, 55, 0.13);
  background: rgba(255, 250, 241, 0.70);
}

.heatmap-day.sent {
  background: rgba(77, 72, 65, 0.72);
  border-color: rgba(77, 72, 65, 0.72);
}

.heatmap-day.received {
  background: rgba(166, 66, 49, 0.82);
  border-color: rgba(166, 66, 49, 0.82);
}

.heatmap-day.both {
  background: linear-gradient(135deg, rgba(77, 72, 65, 0.82) 0%, rgba(77, 72, 65, 0.82) 48%, rgba(166, 66, 49, 0.88) 52%, rgba(166, 66, 49, 0.88) 100%);
  border-color: rgba(116, 57, 45, 0.70);
}

.heatmap-day.favorited {
  border-color: var(--gold-color);
  box-shadow: 0 0 0 2rpx rgba(176, 122, 31, 0.18);
}

.heatmap-day.selected {
  border-color: var(--ink-color);
  box-shadow:
    0 0 0 2rpx rgba(36, 33, 29, 0.18),
    0 4rpx 10rpx rgba(36, 33, 29, 0.12);
}

.heatmap-day.future {
  opacity: 0.35;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: var(--text-muted);
}

/* 时间轴 */
.timeline {
  position: relative;
  padding-left: 22rpx;
}

.timeline-line {
  position: absolute;
  left: 7rpx;
  top: 0;
  bottom: 0;
  width: 1rpx;
  background: linear-gradient(
    180deg,
    rgba(77, 72, 65, 0.22) 0%,
    rgba(176, 122, 31, 0.24) 48%,
    rgba(166, 66, 49, 0.24) 100%
  );
}

.timeline-item {
  position: relative;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
}

/* 时间点 */
.timeline-dot {
  position: absolute;
  left: -20rpx;
  top: 20rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 1rpx;
  z-index: 1;
}

.timeline-dot.sent {
  background: var(--timeline-sent);
}

.timeline-dot.received {
  background: var(--timeline-received);
}

/* 书签卡片 */
.bookmark {
  flex: 1;
  margin-left: 24rpx;
  padding: 22rpx 26rpx;
  border-radius: 6rpx;
  border: 1rpx solid var(--border-color);
  border-left: 4rpx solid;
  position: relative;
  box-shadow:
    0 6rpx 18rpx rgba(74, 60, 43, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.bookmark.sent {
  background: #fff9ee;
  background-image:
    linear-gradient(90deg, rgba(77, 72, 65, 0.055) 0%, rgba(176, 122, 31, 0.030) 38%, rgba(77, 72, 65, 0) 70%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.80) 0%, rgba(255, 248, 236, 0.96) 100%);
  border-color: rgba(77, 72, 65, 0.24);
  border-left-color: var(--timeline-sent);
}

.bookmark.received {
  background: #fff9ee;
  background-image:
    linear-gradient(90deg, rgba(166, 66, 49, 0.065) 0%, rgba(176, 122, 31, 0.030) 40%, rgba(166, 66, 49, 0) 74%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.80) 0%, rgba(255, 248, 236, 0.96) 100%);
  border-color: rgba(166, 66, 49, 0.28);
  border-left-color: var(--timeline-received);
}

.bookmark.favorited {
  border-color: rgba(176, 122, 31, 0.54);
  border-left-color: var(--gold-color);
  background-image:
    linear-gradient(90deg, rgba(176, 122, 31, 0.13) 0%, rgba(176, 122, 31, 0.035) 42%, rgba(176, 122, 31, 0) 76%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.84) 0%, rgba(255, 248, 236, 0.96) 100%);
  box-shadow:
    0 6rpx 18rpx rgba(176, 122, 31, 0.11),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.bookmark-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.bookmark-header-left {
  display: flex;
  align-items: center;
}

.bookmark-date {
  font-size: 23rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

/* 作者昵称标签 */
.bookmark-author-left {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.bookmark-author-left.mine {
  background: var(--timeline-sent-soft);
  color: var(--timeline-sent);
}

.bookmark-author-left.partner {
  background: var(--timeline-received-soft);
  color: var(--timeline-received);
}

.bookmark-image-mark {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(63, 60, 55, 0.16);
  color: #4d4841;
  background: rgba(63, 60, 55, 0.055);
  margin-left: 12rpx;
}

.footer-read {
  font-size: 20rpx;
  color: var(--timeline-received);
  letter-spacing: 1rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  background: var(--timeline-received-soft);
}

.footer-unread {
  font-size: 20rpx;
  color: var(--seal-color);
  letter-spacing: 1rpx;
}

/* 词云区域 — 透明融入页面 */
.word-cloud-card {
  margin-bottom: 32rpx;
  padding: 26rpx 8rpx;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
}

.word-cloud-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-cloud-title {
  font-size: 26rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
}

.word-cloud-toggle {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  opacity: 0.7;
}

.word-cloud-body {
  margin-top: 24rpx;
}

.word-cloud-scatter {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.cloud-word {
  position: absolute;
  white-space: nowrap;
  font-family: 'TimeLagKaiti', 'STKaiti', 'KaiTi', 'PingFang SC', serif;
}

.word-cloud-footnote {
  text-align: center;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
