/* pages/timeline/timeline.wxss - 重新设计，左右分区 */
.container {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.header {
  padding: 32rpx 16rpx;
  text-align: center;
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
  padding: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-item text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.mine {
  background: var(--seal-color);
}

.legend-dot.partner {
  background: var(--text-muted);
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.streak-text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx;
  color: var(--text-muted);
}

/* 时间轴列表 - 左右分区 */
.timeline-list {
  position: relative;
  padding: 0 16rpx;
}

/* 中央时间线 */
.timeline-list::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: var(--border-color);
  transform: translateX(-50%);
}

.timeline-item {
  position: relative;
  margin-bottom: 48rpx;
  display: flex;
  align-items: flex-start;
}

/* 我写的信 - 左侧 */
.timeline-item.mine {
  flex-direction: row;
  padding-right: 50%;
}

/* 对方写的信 - 右侧 */
.timeline-item.partner {
  flex-direction: row-reverse;
  padding-left: 50%;
}

/* 时间点 */
.timeline-dot {
  position: absolute;
  left: 50%;
  top: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--paper-color);
  border: 3rpx solid var(--border-color);
  transform: translateX(-50%);
  z-index: 1;
}

.timeline-item.mine .timeline-dot {
  border-color: var(--seal-color);
  background: var(--seal-color);
}

.timeline-item.partner .timeline-dot {
  border-color: var(--text-muted);
  background: var(--text-muted);
}

/* 信件内容区 */
.timeline-content {
  width: calc(50% - 32rpx);
}

.timeline-item.mine .timeline-content {
  margin-right: 32rpx;
}

.timeline-item.partner .timeline-content {
  margin-left: 32rpx;
}

/* 信件卡片 */
.letter-card {
  padding: 24rpx;
  border-radius: 4rpx;
}

.timeline-item.mine .letter-card {
  background: rgba(139, 69, 19, 0.05);
  border: 1rpx solid rgba(139, 69, 19, 0.15);
}

.timeline-item.partner .letter-card {
  background: rgba(139, 115, 85, 0.05);
  border: 1rpx solid rgba(139, 115, 85, 0.15);
}

.letter-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.letter-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.letter-badge {
  padding: 4rpx 12rpx;
  border-radius: 2rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.letter-badge.mine {
  background: rgba(139, 69, 19, 0.1);
  color: var(--seal-color);
}

.letter-badge.read {
  background: rgba(139, 115, 85, 0.1);
  color: var(--text-secondary);
}

.letter-badge.unread {
  background: var(--seal-color);
  color: #f0e6d6;
}

.letter-preview {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 发送者标签 */
.sender-label {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.timeline-item.mine .sender-label {
  text-align: right;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  color: var(--text-muted);
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
