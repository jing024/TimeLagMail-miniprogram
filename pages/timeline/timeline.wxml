<!-- pages/timeline/timeline.wxml - 书签式时间轴 -->
<view class="container">
  <!-- 连续通信提示 -->
  <view class="streak-info" wx:if="{{streak > 0}}">
    <text class="streak-text">已连续通信 {{streak}} 日</text>
  </view>

  <!-- 图例 + 筛选 -->
  <view class="legend">
    <view class="legend-item">
      <view class="legend-marker sent"></view>
      <text>寄出</text>
    </view>
    <view class="legend-item">
      <view class="legend-marker received"></view>
      <text>收到</text>
    </view>
    <text class="filter-btn {{favoriteOnly ? 'active' : ''}}" bindtap="toggleFavoriteFilter">仅收藏</text>
  </view>

  <!-- 共同回忆词云 -->
  <view class="word-cloud-card" wx:if="{{!loading && allLetters.length >= 5 && !favoriteOnly}}">
    <view class="word-cloud-header" bindtap="toggleWordCloud">
      <text class="word-cloud-title">共同回忆</text>
      <text class="word-cloud-toggle">{{wordCloudExpanded ? '收起' : '展开'}}</text>
    </view>
    <view class="word-cloud-body" wx:if="{{wordCloudExpanded}}">
      <view class="word-cloud-scatter" wx:if="{{wordCloudWords.length > 0}}">
        <text
          wx:for="{{wordCloudWords}}"
          wx:key="text"
          class="cloud-word"
          style="font-size:{{item.fontSize}}rpx; left:{{item.x}}rpx; top:{{item.y}}rpx; opacity:{{item.opacity}}; color:{{item.color}};">{{item.text}}</text>
      </view>
      <view class="loading" wx:elif="{{wordCloudLoading}}">
        <text>加载中...</text>
      </view>
      <view class="word-cloud-footnote" wx:if="{{totalLetters > 0}}">
        <text>来自 {{totalLetters}} 封信的共同记忆</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 时间轴列表 -->
  <view class="timeline" wx:elif="{{letters.length > 0}}">
    <view class="timeline-line"></view>

    <view class="timeline-item" wx:for="{{letters}}" wx:key="_id">
      <!-- 时间点 -->
      <view class="timeline-dot {{item.isMine ? 'sent' : 'received'}}"></view>

      <!-- 书签卡片 -->
      <view class="bookmark {{item.isMine ? 'sent' : 'received'}} {{item.isFavorited ? 'favorited' : ''}}" bindtap="openLetter" data-id="{{item._id}}">
        <view class="bookmark-header">
          <view class="bookmark-header-left">
            <text class="bookmark-date">{{item.dateStr}}</text>
            <text class="bookmark-author-left {{item.isMine ? 'mine' : 'partner'}}">{{item.authorName}}</text>
          </view>
          <text wx:if="{{!item.isMine}}" class="{{item.isRead ? 'footer-read' : 'footer-unread'}}">{{item.isRead ? '已开启' : '待开启'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading}}">
    <view class="empty-icon">—</view>
    <view class="empty-text">{{favoriteOnly ? '尚未收藏信件' : '尚无记录'}}</view>
    <view class="empty-hint">{{favoriteOnly ? '在信件详情中点击收藏' : '等待第一封信'}}</view>
  </view>
</view>
