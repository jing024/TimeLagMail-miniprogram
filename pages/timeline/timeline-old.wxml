<!-- pages/timeline/timeline.wxml - 左右分区设计 -->
<view class="container">
  <view class="header">
    <view class="header-title">时光轴</view>
    <view class="streak-info" wx:if="{{streak > 0}}">
      <text class="streak-text">已连续通信 {{streak}} 日</text>
    </view>
  </view>

  <!-- 图例说明 -->
  <view class="legend" wx:if="{{letters.length > 0}}">
    <view class="legend-item">
      <view class="legend-dot mine"></view>
      <text>寄出</text>
    </view>
    <view class="legend-item">
      <view class="legend-dot partner"></view>
      <text>收到</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 信件列表 -->
  <view class="timeline-list" wx:elif="{{letters.length > 0}}">
    <view class="timeline-item {{item.isMine ? 'mine' : 'partner'}}" 
          wx:for="{{letters}}" 
          wx:key="_id">
      <view class="timeline-dot"></view>
      <view class="timeline-content">
        <view class="paper-card letter-card">
          <view class="letter-meta">
            <text class="letter-date">{{item.dateStr}}</text>
            <view class="letter-badge {{item.isMine ? 'mine' : (item.isRead ? 'read' : 'unread')}}">
              {{item.isMine ? '寄出' : (item.isRead ? '已收' : '待启')}}
            </view>
          </view>
          <view class="letter-preview handwriting">
            {{item.preview}}
          </view>
          <view class="sender-label">{{item.isMine ? '我' : '对方'}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">—</view>
    <view class="empty-text">尚无记录</view>
    <view class="empty-hint">等待第一封信</view>
  </view>
</view>
