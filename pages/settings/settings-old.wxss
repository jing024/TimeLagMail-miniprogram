/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.header {
  padding: 32rpx 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 300;
}

/* 用户卡片 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  margin-bottom: 24rpx;
  background: var(--bg-color);
}

.user-name {
  font-size: 36rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.user-status {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.paired {
  background: var(--success-color);
}

.status-dot.unpaired {
  background: var(--warning-color);
}

/* 设置列表 */
.settings-list {
  margin-top: 32rpx;
}

.settings-group {
  background: var(--paper-color);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.settings-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-label.logout {
  color: var(--error-color);
  text-align: center;
  width: 100%;
}

.item-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
}

.logout-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: inherit;
}

.logout-btn::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 48rpx;
}

.version-info text {
  font-size: 24rpx;
  color: var(--text-muted);
}
