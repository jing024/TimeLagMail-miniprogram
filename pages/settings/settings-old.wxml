<!-- pages/settings/settings.wxml -->
<view class="container">
  <view class="header">
    <view class="header-title">设置</view>
  </view>

  <!-- 用户信息 -->
  <view class="paper-card user-card" wx:if="{{userInfo}}">
    <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
    <view class="user-name">{{userInfo.nickName}}</view>
    <view class="user-status" wx:if="{{isPaired}}">
      <text class="status-dot paired"></text>
      <text>已与 {{partnerInfo.nickName || 'Ta'}} 配对</text>
    </view>
    <view class="user-status" wx:else>
      <text class="status-dot unpaired"></text>
      <text>未配对</text>
    </view>
  </view>

  <!-- 设置选项 -->
  <view class="settings-list">
    <view class="settings-group">
      <view class="settings-item" bindtap="goToPairing" wx:if="{{!isPaired}}">
        <text class="item-label">去配对</text>
        <text class="item-arrow">></text>
      </view>
      
      <view class="settings-item" bindtap="showAbout">
        <text class="item-label">关于时差信</text>
        <text class="item-arrow">></text>
      </view>
    </view>

    <view class="settings-group">
      <button class="settings-item logout-btn" bindtap="handleLogout">
        <text class="item-label logout">退出登录</text>
      </button>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>时差信 v1.0.0</text>
  </view>
</view>
