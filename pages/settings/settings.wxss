/* pages/settings/settings.wxss - 简化设置页 */
.container {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.header {
  padding: 32rpx 16rpx;
  text-align: center;
}

.header-title {
  font-size: 36rpx;
  font-weight: 400;
  letter-spacing: 8rpx;
  color: var(--text-primary);
}

/* 设置列表 */
.settings-list {
  margin-top: 32rpx;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  background: var(--paper-light);
  background-image:
    radial-gradient(ellipse at 30% 0%, rgba(255, 252, 245, 0.5) 0%, transparent 60%);
  border-radius: 14rpx;
  border: none;
  box-shadow:
    inset 0 2rpx 6rpx rgba(255, 252, 245, 0.6),
    inset 0 -1rpx 4rpx rgba(61, 41, 20, 0.07),
    0 1rpx 3rpx rgba(61, 41, 20, 0.06);
  margin-bottom: 14rpx;
}

.item-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.item-label {
  font-size: 30rpx;
  color: var(--text-primary);
  letter-spacing: 0;
  vertical-align: middle;
}

.item-label-wrap {
  display: flex;
  align-items: center;
}

.item-value {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 0;
  vertical-align: middle;
}

/* 来信通知行：label 和 value 各自独立垂直居中 */
.subscribe-row {
  display: flex;
  align-items: center;
}

.subscribe-label,
.subscribe-value {
  display: flex;
  align-items: center;
}

.subscribe-label {
  flex-shrink: 0;
}

.subscribe-value {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.subscribe-row .item-arrow {
  flex-shrink: 0;
  margin-left: auto;
}

.version-tag {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0;
  line-height: 1;
}

.item-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

.settings-item.logout .item-label {
  color: var(--seal-color);
}

/* 时间选择器弹窗 */
.time-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.time-picker {
  width: 100%;
  background: var(--paper-color);
  border-radius: 16rpx 16rpx 0 0;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.picker-cancel {
  font-size: 30rpx;
  color: var(--text-muted);
}

.picker-title {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.picker-confirm {
  font-size: 30rpx;
  color: var(--seal-color);
}

.picker-view {
  height: 400rpx;
}

.picker-item {
  line-height: 80rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--text-primary);
}

/* 配对信息弹窗 */
.partner-modal {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.partner-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  border: 2rpx solid var(--border-color);
}

.partner-name {
  font-size: 32rpx;
  color: var(--text-primary);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.partner-status {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.no-partner {
  text-align: center;
  padding: 48rpx;
}

.no-partner-text {
  font-size: 28rpx;
  color: var(--text-muted);
  letter-spacing: 2rpx;
  margin-bottom: 32rpx;
}
